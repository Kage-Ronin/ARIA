# Copy this file to .env and fill in real values before running.
# Generate JWT_SECRET with: python3 -c "import secrets; print(secrets.token_hex(32))"

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
GEMINI_API_KEY=your-gemini-api-key
JWT_SECRET=generate-with-command-above

ADMIN_USERNAME=admin
ADMIN_PASSWORD=set-a-strong-password
USER_USERNAME=user
USER_PASSWORD=set-a-strong-password

# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# Set to "production" to enforce strong-secret validation and secure cookies
ENV=development

# Port (Render/Railway/Fly set $PORT automatically; leave as 8000 for local dev)
PORT=8000

# Memsy Integration
MEMSY_API_KEY=add-memsy-api-key-here
MEMSY_BASE_URL=https://api.memsy.io/v1

# ── Gemini Live (voice) ──────────────────────────────────────────────────────
# LIVE_MODEL=gemini-3.1-flash-live-preview
# GEMINI_API_VERSION=v1beta
# VOICE_NAME=Aoede
# AUDIO_MIME_TYPE=audio/pcm;rate=16000

# ── Gemini Embeddings ────────────────────────────────────────────────────────
# EMBEDDING_MODEL=models/gemini-embedding-001
# EMBEDDING_DIMENSIONS=768

# ── RAG / retrieval ──────────────────────────────────────────────────────────
# CHUNK_MAX_CHARS=2400
# CHUNK_OVERLAP_CHARS=400
# DISTANCE_THRESHOLD=0.55
# RELATIVE_MARGIN=0.12

# ── Conversation history ─────────────────────────────────────────────────────
# HISTORY_LIMIT=20
# HISTORY_CONTEXT_TURNS=12

# ── Database connection pool ─────────────────────────────────────────────────
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_HOURS=12
# TICKET_EXPIRE_SECONDS=60
# WS_TICKET_TOKEN_BYTES=32
